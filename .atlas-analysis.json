  "keyFeatures": [
    "Zero configuration - no decorators or config files needed",
    "Full TypeScript type safety with compile-time checks",
    "Eloquent-style fluent API for elegant queries",
    "Rich query builder with comparison operators",
    "Built-in aggregation functions (count, sum, average, min, max, percentile)",
    "Type-safe relationships between models",
    "Automatic NoSQL injection protection",
    "Automatic MongoDB connection handling",
    "firstOrCreate for upsert operations"
  ],
